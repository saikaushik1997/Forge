# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Telegram (optional — required if using Telegram channel integration)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Encryption key for storing bot tokens at rest — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FORGE_ENCRYPTION_KEY=your_fernet_key_here

# Web Search (optional — agents with web_search tool need this)
TAVILY_API_KEY=your_tavily_api_key_here

# LangSmith observability (optional — leave blank to disable)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=forge

# PostgreSQL
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge
POSTGRES_DB=forge

# Redis
REDIS_URL=redis://redis:6379
